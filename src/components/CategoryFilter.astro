---
import { categories } from '../data/products';
---

<nav
	aria-label="Categorías de productos"
	class="no-scrollbar flex snap-x snap-proximity lg:max-w-[1278px] mx-auto flex-nowrap justify-start gap-6 mt-[124px] overflow-x-auto py-4 lg:py-6 w-full"
>
	{
		categories.map((category) => (
			<button
				type="button"
				data-category={category}
				class="category-btn flex h-auto overflow-visible w-auto px-[26px] py-[10px] items-center justify-center rounded-full bg-white text-[20px] uppercase transition-all duration-200 hover:scale-105 hover:border-brand-purple hover:text-brand-purple active:scale-95 aria-pressed:border-brand-purple aria-pressed:bg-brand-purple aria-pressed:text-white"
				aria-pressed="false"
			>
				{category}
			</button>
		))
	}
</nav>

<script>
	const buttons = document.querySelectorAll<HTMLButtonElement>('.category-btn');
	const cards = document.querySelectorAll<HTMLElement>('.product-card');

	function applyFilter() {
		const activeCategories = Array.from(buttons)
			.filter((b) => b.getAttribute('aria-pressed') === 'true')
			.map((b) => b.dataset.category);

		cards.forEach((card) => {
			const matches = activeCategories.length === 0 || activeCategories.includes(card.dataset.category);
			card.classList.toggle('hidden', !matches);
		});
	}

	buttons.forEach((button) => {
		button.addEventListener('click', () => {
			const alreadyActive = button.getAttribute('aria-pressed') === 'true';
			button.setAttribute('aria-pressed', alreadyActive ? 'false' : 'true');
			applyFilter();
		});
	});
</script>
