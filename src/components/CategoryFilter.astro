---
import { categories } from '../data/products';
---

<nav
	aria-label="Categorías de productos"
	class="no-scrollbar flex snap-x snap-proximity flex-nowrap mt-32 justify-start gap-3 overflow-x-auto px-4 py-6 sm:flex-wrap sm:justify-center sm:overflow-visible sm:px-8"
>
	{
		categories.map((category) => (
			<button
				type="button"
				data-category={category}
				class="category-btn flex h-[47px] w-[175px] shrink-0 snap-start items-center justify-center rounded-full border border-gray-200 bg-white text-[20px] uppercase shadow-sm transition-all duration-200 hover:scale-105 hover:border-brand-purple hover:text-brand-purple active:scale-95 aria-pressed:border-brand-purple aria-pressed:bg-brand-purple aria-pressed:text-white"
				aria-pressed="false"
			>
				{category}
			</button>
		))
	}
</nav>

<script>
	const buttons = document.querySelectorAll<HTMLButtonElement>('.category-btn');
	const cards = document.querySelectorAll<HTMLElement>('.product-card');

	buttons.forEach((button) => {
		button.addEventListener('click', () => {
			const alreadyActive = button.getAttribute('aria-pressed') === 'true';

			buttons.forEach((b) => b.setAttribute('aria-pressed', 'false'));

			if (alreadyActive) {
				cards.forEach((card) => card.classList.remove('hidden'));
				return;
			}

			button.setAttribute('aria-pressed', 'true');
			const category = button.dataset.category;
			cards.forEach((card) => {
				card.classList.toggle('hidden', card.dataset.category !== category);
			});
		});
	});
</script>
