---
import { categories } from '../data/products';
---

<div class="max-w-[1636px] w-full mx-auto px-6 md:px-12">
	<div class="w-full lg:w-full mx-auto">

		<nav
			aria-label="Categorías de productos"
			class="no-scrollbar flex snap-x snap-proximity flex-nowrap justify-start lg:justify-center gap-6 mt-[123px] overflow-x-auto py-6 w-full"
		>
		{
			categories.map((category) => (
				<button
					type="button"
					data-category={category}
					class="category-btn flex h-auto w-auto px-[26px] py-[10px] shrink-0 snap-start items-center justify-center rounded-full bg-white text-[20px] uppercase transition-all duration-200 hover:scale-105 hover:border-brand-purple hover:text-brand-purple active:scale-95 aria-pressed:border-brand-purple aria-pressed:bg-brand-purple aria-pressed:text-white"
					aria-pressed="false"
				>
					{category}
				</button>
			))
		}
		</nav>

	</div>
</div>

<script>
	const buttons = document.querySelectorAll<HTMLButtonElement>('.category-btn');
	const cards = document.querySelectorAll<HTMLElement>('.product-card');

	function applyFilter() {
		const activeCategories = Array.from(buttons)
			.filter((b) => b.getAttribute('aria-pressed') === 'true')
			.map((b) => b.dataset.category);

		cards.forEach((card) => {
			const matches = activeCategories.length === 0 || activeCategories.includes(card.dataset.category);
			card.classList.toggle('hidden', !matches);
		});
	}

	buttons.forEach((button) => {
		button.addEventListener('click', () => {
			const alreadyActive = button.getAttribute('aria-pressed') === 'true';
			button.setAttribute('aria-pressed', alreadyActive ? 'false' : 'true');
			applyFilter();
		});
	});
</script>
