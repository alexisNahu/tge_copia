---
import logo from '../assets/logo_fontotransparente.png';
import facebook from '../assets/facebook_blanco.png';
import instagram from '../assets/ig_blanco.png';
import {Image} from 'astro:assets'
const navLinks = [{ label: 'Descargar el catálogo', href: 'https://www.tge.com.py/catalogo/Catalogo-TGE-2026.pdf' }];
const social = [
	{ label: 'Facebook', href: 'https://www.facebook.com/share/1EhyVZGdbs/?mibextid=wwXIfr', icon: facebook },
	{ label: 'Instagram', href: 'https://www.instagram.com/tg_electrodomesticos/', icon: instagram },
];
---

<header class="absolute inset-x-0 top-0 z-20 flex p-6 md:px-24 min-[1636px]:px-0! w-full items-center justify-between md:mt-[52px] mt-3 max-w-[1636px] mx-auto bg-transparent">
	<a href="#top" class="block transition-transform duration-300 hover:scale-105">
		<Image src={logo} alt="TGE Electrodomésticos" class="md:h-[90px] md:w-[119px] h-[60px] w-[89px]" />
	</a>
	<div class="flex items-center gap-[28px]">
		{
			navLinks.map((link) => (
				/* CAMBIO AQUÍ: Se agregó 'download' y 'target="_blank"' */
				<a
					href={link.href}
					download="Catalogo-TGE-2026.pdf"
					target="_blank"
					class="hidden text-[20px] text-white uppercase transition-colors duration-200 hover:text-white/80 sm:inline"
				>
					{link.label}
				</a>
			))
		}
		<div class="flex items-center gap-2">
			{
				social.map((item) => (
					<a
						href={item.href}
						target="_blank"
						rel="noopener noreferrer"
						aria-label={item.label}
						class="flex h-full w-full items-center justify-center rounded transition-transform duration-200 hover:scale-110"
					>
						<Image src={item.icon} alt="" class="h-[55px] w-[55px] object-contain" />
					</a>
				))
			}
		</div>
	</div>
</header>

<div
	id="sticky-nav"
	class="fixed inset-x-0 top-0 z-50 -translate-y-full transition-transform duration-300 ease-out bg-transparent box-border"
>
	<div class="flex items-center justify-between px-6 py-3 sm:px-12">
		<a href="#top" class="block transition-transform duration-300 hover:scale-105">
			<Image src={logo} alt="TGE Electrodomésticos" class="h-8 w-auto" />
		</a>
		<div class="flex items-center gap-5">
			{
				navLinks.map((link) => (
					/* CAMBIO AQUÍ: Se agregó también al menú sticky para que funcione igual */
					<a
						href={link.href}
						download="Catalogo-TGE-2026.pdf"
						target="_blank"
						class="hidden text-xs font-semibold tracking-wide text-brand-indigo uppercase transition-colors duration-200 hover:text-brand-purple sm:inline"
					>
						{link.label}
					</a>
				))
			}
			<div class="flex items-center gap-2">
				{
					social.map((item) => (
						<a
							href={item.href}
							target="_blank"
							rel="noopener noreferrer"
							aria-label={item.label}
							class="flex h-7 w-7 items-center justify-center rounded p-1.5 transition-transform duration-200 hover:scale-110"
						>
							<Image src={item.icon} alt="" class="h-full w-full object-contain" />
						</a>
					))
				}
			</div>
		</div>
	</div>
</div>
