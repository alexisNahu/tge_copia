---
import logo from '../assets/logo_fontotransparente.png';
import facebook from '../assets/facebook_blanco.png';
import instagram from '../assets/ig_blanco.png';
import facebookColor from '../assets/uil_facebook.png';
import instagramColor from '../assets/streamline_instagram-solid.png';
import {Image} from 'astro:assets'
const navLinks = [{ label: 'Descargar el catálogo', href: 'https://www.tge.com.py/catalogo/Catalogo-TGE-2026.pdf' }];
const social = [
	{ label: 'Facebook', href: 'https://www.facebook.com/share/1EhyVZGdbs/?mibextid=wwXIfr', icon: facebook },
	{ label: 'Instagram', href: 'https://www.instagram.com/tg_electrodomesticos/', icon: instagram },
];
const socialColor = [
	{ label: 'Facebook', href: 'https://www.facebook.com/share/1EhyVZGdbs/?mibextid=wwXIfr', icon: facebookColor },
	{ label: 'Instagram', href: 'https://www.instagram.com/tg_electrodomesticos/', icon: instagramColor },
];
---

<header
	id="site-header"
	class="fixed inset-x-0 top-0 z-50 mx-auto flex w-full max-w-[1636px] items-center justify-between bg-brand-indigo/95 backdrop-blur-md shadow-lg p-6 mt-0 transition-[background-color,box-shadow,margin,padding] duration-300 ease-out sm:bg-transparent sm:shadow-none sm:backdrop-blur-none sm:mt-3 md:mt-[52px] md:px-24 min-[1636px]:px-0!"
>
	<a href="#top" class="block transition-transform duration-300 hover:scale-105">
		<Image src={logo} alt="TGE Electrodomésticos" id="site-logo" class="h-11 w-auto transition-[height] duration-300 md:h-[90px] md:w-[119px]" />
	</a>

	<div
		id="mobile-menu"
		class="absolute inset-x-0 top-full flex -translate-y-4 flex-col items-center gap-4 bg-brand-indigo/95 backdrop-blur-md px-6 py-8 opacity-0 shadow-xl pointer-events-none transition-[opacity,transform] duration-300 ease-out sm:hidden rounded-b-2xl"
	>
		{
			navLinks.map((link) => (
				<a
					href={link.href}
					download="Catalogo-TGE-2026.pdf"
					target="_blank"
					class="flex w-full max-w-[320px] items-center justify-center gap-2 rounded-full bg-gradient-to-r from-[#C570AD] to-[#3e55a5] px-6 py-3 text-[14px] font-bold uppercase tracking-wide text-white shadow-md transition-transform duration-200 hover:scale-105 active:scale-95"
				>
					<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="h-4 w-4">
						<path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5m-13.5-9L12 12m0 0l4.5-4.5M12 12V3" />
					</svg>
					{link.label}
				</a>
			))
		}

		{/* Redes sociales visibles ÚNICAMENTE al abrir la hamburguesa */}
		<div class="flex items-center gap-4 mt-2">
			{
				socialColor.map((item) => (
					<a
						href={item.href}
						target="_blank"
						rel="noopener noreferrer"
						aria-label={item.label}
						class="flex items-center justify-center rounded transition-transform duration-200 hover:scale-110"
					>
						<Image src={item.icon} alt="" class="h-11 w-11 object-contain" />
					</a>
				))
			}
		</div>
	</div>

	<div class="flex items-center gap-6 sm:gap-[28px]">
		{
			navLinks.map((link) => (
				<a
					href={link.href}
					download="Catalogo-TGE-2026.pdf"
					target="_blank"
					class="hidden items-center gap-2 rounded-full bg-gradient-to-r from-[#C570AD] to-[#3e55a5] px-6 py-3 text-[14px] font-bold uppercase tracking-wide text-white shadow-md transition-transform duration-200 hover:scale-105 active:scale-95 sm:flex"
				>
					<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="h-4 w-4">
						<path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5m-13.5-9L12 12m0 0l4.5-4.5M12 12V3" />
					</svg>
					{link.label}
				</a>
			))
		}

		<div class="hidden sm:flex items-center gap-2">
			{
				social.map((item) => (
					<a
						href={item.href}
						target="_blank"
						rel="noopener noreferrer"
						aria-label={item.label}
						class="flex h-full w-full items-center justify-center rounded transition-transform duration-200 hover:scale-110"
					>
						<Image src={item.icon} alt="" class="h-[55px] w-[55px] object-contain" />
					</a>
				))
			}
		</div>

		<button
			type="button"
			id="mobile-menu-toggle"
			aria-expanded="false"
			aria-controls="mobile-menu"
			aria-label="Abrir menú"
			class="relative flex h-8 w-8 shrink-0 items-center justify-center sm:hidden z-30"
		>
			<span class="absolute left-1/2 top-1/2 h-0.5 w-6 -translate-x-1/2 -translate-y-2 rounded-full bg-white transition-transform duration-300 ease-in-out"></span>
			<span class="absolute left-1/2 top-1/2 h-0.5 w-6 -translate-x-1/2 rounded-full bg-white transition-opacity duration-200 ease-in-out"></span>
			<span class="absolute left-1/2 top-1/2 h-0.5 w-6 -translate-x-1/2 translate-y-2 rounded-full bg-white transition-transform duration-300 ease-in-out"></span>
		</button>
	</div>
</header>

<script>
	const header = document.getElementById('site-header');
	const logo = document.getElementById('site-logo');
	const SCROLL_THRESHOLD = 40;

	function updateHeaderOnScroll() {
		const isScrolled = window.scrollY > SCROLL_THRESHOLD;

		header?.classList.toggle('sm:bg-brand-indigo/95', isScrolled);
		header?.classList.toggle('sm:backdrop-blur-md', isScrolled);
		header?.classList.toggle('sm:shadow-lg', isScrolled);
		header?.classList.toggle('sm:bg-transparent', !isScrolled);
		header?.classList.toggle('sm:backdrop-blur-none', !isScrolled);
		header?.classList.toggle('sm:shadow-none', !isScrolled);

		header?.classList.toggle('sm:mt-3', !isScrolled);
		header?.classList.toggle('md:mt-[52px]', !isScrolled);

		logo?.classList.toggle('md:h-[90px]', !isScrolled);
		logo?.classList.toggle('md:w-[119px]', !isScrolled);
		logo?.classList.toggle('md:h-14', isScrolled);
	}

	updateHeaderOnScroll();
	window.addEventListener('scroll', updateHeaderOnScroll, { passive: true });

	const menuToggle = document.getElementById('mobile-menu-toggle');
	const mobileMenu = document.getElementById('mobile-menu');
	const [barTop, barMid, barBottom] = menuToggle?.querySelectorAll('span') ?? [];

	function setMenuOpen(isOpen: boolean) {
		mobileMenu?.classList.toggle('opacity-0', !isOpen);
		mobileMenu?.classList.toggle('-translate-y-4', !isOpen);
		mobileMenu?.classList.toggle('pointer-events-none', !isOpen);

		barTop?.classList.toggle('-translate-y-2', !isOpen);
		barTop?.classList.toggle('rotate-45', isOpen);
		barMid?.classList.toggle('opacity-0', isOpen);
		barBottom?.classList.toggle('translate-y-2', !isOpen);
		barBottom?.classList.toggle('-rotate-45', isOpen);

		menuToggle?.setAttribute('aria-expanded', String(isOpen));
		menuToggle?.setAttribute('aria-label', isOpen ? 'Cerrar menú' : 'Abrir menú');
	}

	menuToggle?.addEventListener('click', () => {
		setMenuOpen(mobileMenu?.classList.contains('opacity-0') ?? false);
	});

	mobileMenu?.querySelectorAll('a').forEach((link) => {
		link.addEventListener('click', () => setMenuOpen(false));
	});
</script>
