---
import { Image } from 'astro:assets';
import banner from '../assets/banner.png';
---
<section id="top" class="relative h-screen min-h-[560px] overflow-hidden w-full">
	<Image
		src={banner}
		alt="Living room with a smart TV on a wooden stand"
		class="absolute inset-0 h-full w-full object-cover animate-[ken-burns_20s_ease-in-out_infinite_alternate]"
		fetchpriority="high"
	/>

	<div class="absolute bottom-0 left-0 right-0 z-10 flex flex-col max-w-[1700px] w-full mx-auto px-6 pb-20">
		<h1 class="text-3xl sm:text-5xl md:text-[64px] font-bold text-white animate-[fade-in-up_0.8s_ease-out_both]">
			Calidad y Confianza
		</h1>
		<p class="mt-2 text-lg sm:text-2xl md:text-[40px] text-white leading-tight max-w-4xl animate-[fade-in-up_0.8s_ease-out_0.15s_both]">
			Tecnología para tu hogar, al alcance de todos.
		</p>
	</div>
</section>
