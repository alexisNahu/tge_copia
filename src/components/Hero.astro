---
import { Image } from 'astro:assets';
import banner from '../assets/banner.png';
---

<section id="top" class="relative h-screen min-h-[560px] overflow-hidden">
	<Image
		src={banner}
		alt="Living room with a smart TV on a wooden stand"
		class="absolute inset-0 h-full w-full object-cover"
		fetchpriority="high"
	/>
	<div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/10 to-black/30"></div>
	<div class="relative z-10 flex h-full flex-col justify-end px-6 pb-8 sm:px-12 sm:pb-12 max-w-[1600px] w-full mx-auto">
		<h1 class="text-3xl font-bold text-white sm:text-[64px]">Calidad y Confianza</h1>
		<p class="mt-2 text-sm text-white sm:text-[40px]">
			Tecnología para tu hogar, al alcance de todos.
		</p>
	</div>
</section>
