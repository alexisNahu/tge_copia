---
import { Image } from 'astro:assets';
import banner from '../assets/banner.png';
---
<section id="top" class="relative h-screen min-h-[560px] overflow-hidden w-full">
	{/* MODIFICADO: Añadido 'object-cover' por defecto para móviles y mantenido el 'md:object-center' */}
	<Image
		src={banner}
		alt="Living room with a smart TV on a wooden stand"
		class="absolute inset-0 h-full w-full object-cover md:object-center animate-[ken-burns_20s_ease-in-out_infinite_alternate]"
		fetchpriority="high"
	/>

	<div class="absolute bottom-0 left-0 right-0 z-10 mx-auto grid w-full max-w-[1636px] grid-cols-1 gap-6 px-6 pb-20 md:grid-cols-12 md:px-12">
		<div class="flex flex-col md:col-span-8">
			<h1 class="text-3xl sm:text-5xl md:text-[64px] font-bold text-white animate-[fade-in-up_0.8s_ease-out_both]">
				Calidad y Confianza
			</h1>
			<p class="mt-2 text-lg sm:text-2xl md:text-[40px] text-white animate-[fade-in-up_0.8s_ease-out_0.15s_both]">
				Tecnología para tu hogar, al alcance de todos.
			</p>
		</div>
	</div>
</section>
