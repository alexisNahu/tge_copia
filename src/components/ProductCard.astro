---
import whatsapp from '../assets/ic_baseline-whatsapp.png';
import type { Product } from '../data/products';
import { Image } from "astro:assets";

interface Props {
	product: Product;
}

const { product } = Astro.props;

const WHATSAPP_NUMBER = '595974283765';
const message = `Hola, quiero hacer un pedido de ${product.name}`;
const whatsappHref = `https://wa.me/${WHATSAPP_NUMBER}?text=${encodeURIComponent(message)}`;
---

<article
	class="product-card group relative flex flex-col justify-between rounded-lg bg-white pb-6 shadow-sm w-full min-[1700px]:w-[465px] min-[1700px]:h-[522px] h-full transition-[opacity,transform,box-shadow] duration-300 hover:-translate-y-1.5 hover:shadow-xl"
	data-category={product.category}
	data-name={product.name}
	data-image={product.image.src}
	data-contado={product.contado}
	data-financiado={JSON.stringify(product.financiado)}
	data-whatsapp={whatsappHref}
>
	{
		product.badge && (
			<span class="absolute top-2 right-2 rounded bg-red-600 px-1.5 py-1 text-[9px] font-bold text-white z-10 animate-pulse">
             {product.badge}
          </span>
		)
	}

	{/* Contenedor de la imagen */}
	<div class="w-full flex items-center justify-center p-4 min-h-[270px] md:min-h-[336px]">
		<Image
			src={product.image}
			alt={product.name}
			loading="lazy"
			class={`w-auto h-auto max-w-full max-h-full object-contain transition-transform duration-300 group-hover:scale-110 group-hover:-translate-y-8 ${product.imageDimensions}`}
		/>
	</div>

	{/* MODIFICADO: Cambiado h-auto por h-[64px] md:h-[88px] e introducido margen constante (my-4) */}
	{/* Al reservar exactamente 88px en desktop, todas las cajas h3 medirán lo mismo y los botones nacerán exactamente en el mismo renglón horizontal */}
	<h3 class={`text-center text-[24px] md:text-[32px] justify-start font-bold w-full mx-auto h-[64px] md:h-[88px] flex items-center md:mb-6 break-words my-4 px-2 leading-tight ${product.titleMaxWidth}`}>
		{product.name}
	</h3>

	<div class="mt-auto flex justify-center gap-2 px-4">
		<button
			type="button"
			class="price-toggle flex items-center justify-center rounded-full bg-gradient-to-r from-brand-pink to-brand-purple w-[119px] h-[35px] text-[14px] text-white uppercase cursor-pointer transition-transform duration-200 hover:scale-105 active:scale-95"
			aria-haspopup="dialog"
		>
			Ver precios
		</button>
		<a
			href={whatsappHref}
			target="_blank"
			rel="noopener noreferrer"
			class="inline-flex items-center justify-center gap-1 rounded-full bg-[#1bd3a8] w-[151px] h-[35px] text-[14px] text-white uppercase transition-transform duration-200 hover:scale-105 hover:bg-brand-teal-dark active:scale-95"
		>
			<Image src={whatsapp} alt="" class="h-[14px] w-[14px] brightness-0 invert" />
			Hacer pedido
		</a>
	</div>
</article>
