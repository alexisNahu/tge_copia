---
import whatsapp from '../assets/ic_baseline-whatsapp.png';
import type { Product } from '../data/products';
import {Image} from "astro:assets";

interface Props {
	product: Product;
}

const { product } = Astro.props;

const WHATSAPP_NUMBER = '595974283765';
const message = `Hola, quiero hacer un pedido de ${product.name}`;
const whatsappHref = `https://wa.me/${WHATSAPP_NUMBER}?text=${encodeURIComponent(message)}`;
---

<article
	class="product-card group relative flex flex-col justify-between rounded-lg bg-white pb-6 shadow-sm w-full max-w-[465px] max-h-[522px] f-full transition-all duration-300 hover:-translate-y-1.5 hover:shadow-xl"
	data-category={product.category}
	data-name={product.name}
	data-image={product.image.src}
	data-contado={product.contado}
	data-financiado={JSON.stringify(product.financiado)}
	data-whatsapp={whatsappHref}
>
	{
		product.badge && (
			<span class="absolute top-2 right-2 rounded bg-red-600 px-1.5 py-1 text-[9px] font-bold text-white z-10 animate-pulse">
             {product.badge}
          </span>
		)
	}

	<div class="w-full h-[800px] flex items-center justify-center overflow-hidden">
		<Image
			src={product.image}
			alt={product.name}
			loading="lazy"
			class="w-full h-full object-contain transition-transform duration-300 group-hover:scale-110"
		/>
	</div>

	<h3 class="text-center text-[32px] font-bold md:h-[200px] h-[140px] flex max-w-[370px] w-full mx-auto items-center justify-center line-clamp-2 overflow-hidden my-6">
		{product.name}
	</h3>

	<div class="mt-auto flex justify-center gap-2">
		<button
			type="button"
			class="price-toggle rounded-full bg-gradient-to-r from-brand-pink to-brand-purple px-6 py-1.5 text-[14px] text-white uppercase cursor-pointer transition-transform duration-200 hover:scale-105 active:scale-95"
			aria-haspopup="dialog"
		>
			Ver precios
		</button>
		<a
			href={whatsappHref}
			target="_blank"
			rel="noopener noreferrer"
			class="inline-flex items-center gap-1 rounded-full bg-brand-teal px-3 py-1.5 text-[14px] text-white uppercase transition-transform duration-200 hover:scale-105 hover:bg-brand-teal-dark active:scale-95"
		>
			<Image src={whatsapp} alt="" class="h-[14px] w-[14px] brightness-0 invert" />
			Hacer pedido
		</a>
	</div>
</article>
