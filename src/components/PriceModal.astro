---
import { Image } from 'astro:assets';
import whatsapp from '../assets/ic_baseline-whatsapp.png';
---

<div
	id="price-modal"
	class="fixed inset-0 z-[100] hidden items-center justify-center bg-black/75 px-4 opacity-0 transition-opacity duration-300"
	role="dialog"
	aria-modal="true"
	aria-labelledby="price-modal-title"
>
	{/* MODIFICADO: Se removieron py-6 y sm:py-0; añadidos pt-6 pb-6 md:pt-[77px] md:pb-[73px] */}
	<div
		id="price-modal-panel"
		class="relative w-full h-auto md:w-[904px] md:h-[100dvh] max-h-[100dvh] overflow-y-auto rounded-3xl bg-white pt-6 pb-6 md:pt-[77px] md:pb-[73px] text-center shadow-2xl scale-95 opacity-0 transition-all duration-300 ease-out flex flex-col justify-center"
	>
		<button
			id="price-modal-close"
			type="button"
			aria-label="Cerrar"
			class="absolute top-3 right-4 sm:top-5 sm:right-6 text-2xl sm:text-3xl text-gray-400 transition-all duration-200 hover:rotate-90 hover:text-gray-600"
		>
			&times;
		</button>

		<h3 id="price-modal-title" class="px-8 text-xl font-bold sm:px-0 sm:text-[40px]"></h3>

		<img id="price-modal-image" src="" alt="" class="mx-auto my-3 h-36 w-auto object-contain sm:my-8 sm:h-80" />

		<p class="text-sm uppercase sm:text-[24px]">Contado</p>
		<p id="price-modal-contado" class="mt-1 text-xl sm:text-[36px]"></p>

		<p class="mt-3 text-sm uppercase sm:mt-8 sm:text-[24px]">Financiado</p>

		<div
			id="price-modal-financiado"
			class="mx-auto mt-2 grid w-max max-w-full gap-x-[55px] gap-y-2 text-left text-xs sm:mt-3 sm:text-[24px]"
		>
		</div>

		<a
			id="price-modal-whatsapp"
			href="#"
			target="_blank"
			rel="noopener noreferrer"
			class="mt-4 inline-flex items-center justify-center gap-2 rounded-full bg-brand-teal py-[8px] px-[31px] text-sm text-white uppercase transition-transform duration-200 hover:scale-105 hover:bg-brand-teal-dark active:scale-95 sm:mt-10 sm:text-[24px] self-center"
		>
			<Image src={whatsapp} alt="" class="h-4 w-4 brightness-0 invert sm:h-[24px] sm:w-[24px]" />
			Hacer pedido
		</a>
	</div>
</div>

<script>
	const modal = document.getElementById('price-modal');
	const panel = document.getElementById('price-modal-panel');
	const titleEl = document.getElementById('price-modal-title');
	const imageEl = document.getElementById('price-modal-image') as HTMLImageElement | null;
	const contadoEl = document.getElementById('price-modal-contado');
	const financiadoEl = document.getElementById('price-modal-financiado');
	const whatsappEl = document.getElementById('price-modal-whatsapp') as HTMLAnchorElement | null;

	function openModal(card: HTMLElement) {
		if (!modal) return;
		const { name, image, contado, financiado, whatsapp: whatsappHref } = card.dataset;

		if (titleEl) titleEl.textContent = name ?? '';
		if (imageEl) {
			imageEl.src = image ?? '';
			imageEl.alt = name ?? '';
		}
		if (contadoEl) contadoEl.textContent = `Gs. ${contado ?? ''}`;
		if (whatsappEl && whatsappHref) whatsappEl.href = whatsappHref;

		if (financiadoEl && financiado) {
			const cuotas = JSON.parse(financiado) as { cuotas: number; monto: string }[];
			financiadoEl.style.gridTemplateColumns = `repeat(${cuotas.length}, minmax(0, 1fr))`;
			financiadoEl.innerHTML = cuotas
				.map(
					(c) =>
						`<div><span class="block font-bold">${c.cuotas}x</span>Gs. ${c.monto}</div>`,
				)
				.join('');
		}

		modal.classList.remove('hidden');
		modal.classList.add('flex');
		document.body.classList.add('overflow-hidden');

		// force a reflow so the opacity/scale transition actually plays
		void modal.offsetWidth;
		modal.classList.remove('opacity-0');
		panel?.classList.remove('opacity-0', 'scale-95');
	}

	function closeModal() {
		if (!modal) return;
		modal.classList.add('opacity-0');
		panel?.classList.add('opacity-0', 'scale-95');
		document.body.classList.remove('overflow-hidden');

		window.setTimeout(() => {
			modal.classList.add('hidden');
			modal.classList.remove('flex');
		}, 300);
	}

	document.addEventListener('click', (event) => {
		const target = event.target as HTMLElement;

		const trigger = target.closest<HTMLElement>('.price-toggle');
		if (trigger) {
			const card = trigger.closest<HTMLElement>('.product-card');
			if (card) openModal(card);
			return;
		}

		if (target.id === 'price-modal-close' || target === modal) closeModal();
	});

	document.addEventListener('keydown', (event) => {
		if (event.key === 'Escape') closeModal();
	});
</script>
