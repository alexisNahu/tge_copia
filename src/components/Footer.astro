---
import { Image } from 'astro:assets';
import logo from '../assets/logo.png';
import whatsapp from '../assets/ic_baseline-whatsapp.png';
import facebook from '../assets/uil_facebook.png';
import instagram from '../assets/streamline_instagram-solid.png';
import check from '../assets/line-md_check-all.png';
import seg from '../assets/2.png';
import ter from '../assets/3.png';
const requisitos = ['Cédula de identidad', 'Dirección', 'Comprobantes de ingresos', 'Inforconf'];
const social = [
	{ label: 'Facebook', href: 'https://www.facebook.com/share/1EhyVZGdbs/?mibextid=wwXIfr', icon: facebook },
	{ label: 'Instagram', href: 'https://www.instagram.com/tg_electrodomesticos/', icon: instagram },
];
---

<div class="bg-white">
<footer class="w-full bg-white px-24 min-[1636px]:px-0! py-12 md:py-16 flex items-center h-[100dvh] md:h-[50dvh] justify-center max-w-[1636px] mx-auto">

	<div class="flex flex-col items-center justify-around w-full gap-12 sm:flex-row sm:items-start ">

		{/* Bloque 1: Logo */}
		<div class="flex flex-shrink-0 items-center justify-center">
			<Image src={logo} alt="TGE Electrodomésticos" class="h-[116px] w-auto object-contain" />
		</div>

		{/* Bloque 2: Información de Contacto, Financiación, Envíos */}
		<div class="flex flex-col gap-6 text-[#3A1D28] justify-center">
			{/* Contacto */}
			<div class="flex items-center gap-3">
				<Image src={whatsapp} alt="Whatsapp" class="h-[28px] w-[28px] flex-shrink-0" />
				<div class="flex flex-row flex-wrap items-baseline gap-2 sm:flex-col sm:gap-0">
					<p class="text-[20px] uppercase">Contacto:</p>
					<p class="text-[20px]">0974 283765</p>
				</div>
			</div>

			{/* Financiación */}
			<div class="flex items-center gap-3">
				<Image src={seg} alt="Financiación" class="h-[24px] w-[27px] flex-shrink-0 object-contain" />
				<div class="flex flex-row flex-wrap items-baseline gap-2 sm:flex-col sm:gap-0">
					<p class="text-[20px] uppercase">Financiación:</p>
					<p class="text-[20px]">Pago a los 30 días</p>
				</div>
			</div>

			{/* Aprobación */}
			<div class="flex items-center gap-3">
				<Image src={ter} alt="Aprobación y envíos" class="h-[22px] w-[32px] flex-shrink-0 object-contain" />
				<div class="flex flex-row flex-wrap items-baseline gap-2 sm:flex-col sm:gap-0">
					<p class="text-[20px] uppercase">Aprobación y envíos:</p>
					<p class="text-[20px]">Entre 24 a 48 hs</p>
				</div>
			</div>
		</div>

		{/* Bloque 3: Requisitos */}
		<div class="flex flex-col justify-center">
			<p class="text-[20px] uppercase border-b border-transparent pb-1 mb-2 sm:mb-0">
				Requisitos para acceder a créditos o cuotas
			</p>
			<ul class="flex flex-col gap-2">
				{
					requisitos.map((item) => (
						<li class="flex items-center gap-2.5">
							<Image src={check} alt="" class="h-[24px] w-[24px] flex-shrink-0" />
							<span class="text-[20px]">{item}</span>
						</li>
					))
				}
			</ul>
		</div>

		{/* Bloque 4: Redes Sociales */}
		<div class="flex items-center gap-4 sm:mt-0">
			{
				social.map((item) => (
					<a
						href={item.href}
						target="_blank"
						rel="noopener noreferrer"
						aria-label={item.label}
						class="flex items-center justify-center transition-transform hover:scale-105"
					>
						<img
							src={item.icon.src}
							alt=""
							class="h-[53px] w-[53px] object-contain"
						/>
					</a>
				))
			}
		</div>

	</div>

</footer>
	<div class="w-full bg-[#3E55A5] text-white text-center py-4 text-sm"><a href="https://fincreativo.com" target="_blank">Diseñado y desarrollado por FINCREATIVO</a></div>

</div>
