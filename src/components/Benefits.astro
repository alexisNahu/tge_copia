---
import { Image } from 'astro:assets';
import footerImage from '../assets/footer.png';
import mano_regalo from '../assets/mano_regalo.png';
import moneda from '../assets/moneda.png';
import corazon from '../assets/corazon.png';
---

{/* MODIFICADO: Quitamos las alturas fijas en dvh para que responda de forma natural al contenido */}
<section class="relative overflow-hidden py-20 w-full flex items-center justify-center md:h-[50dvh]">
	<Image src={footerImage} alt="" class="absolute inset-0 h-full w-full object-cover" />
	<div class="absolute inset-0 bg-brand-pink/20"></div>

		<div class="relative z-10 mx-auto grid w-full grid-cols-1 gap-12 px-6 md:px-12 text-center sm:grid-cols-3 max-w-[1636px]">

		{/* Beneficio 1: Regalo / Contado */}
		{/* MODIFICADO: justify-start para alinear el contenido a la izquierda de su columna */}
		<div class="benefit-item flex flex-col items-center justify-start gap-6 transition-all duration-500">
			<Image
				src={mano_regalo}
				alt=""
				class="h-[66px] w-auto object-contain transition-transform duration-300 hover:scale-110"
			/>
			<p class="text-white text-[24px] font-bold max-w-[350px]">
				Comprá al contado con excelentes precios
			</p>
		</div>

		{/* Beneficio 2: Moneda / Cuotas */}
		{/* MODIFICADO: justify-center para centrar el contenido en su columna */}
		<div class="benefit-item flex flex-col items-center justify-center gap-6 transition-all duration-500" style="transition-delay: 120ms">
			<Image
				src={moneda}
				alt=""
				class="h-[58px] w-auto object-contain transition-transform duration-300 hover:scale-110"
			/>
			<p class="text-white text-[24px] font-bold max-w-[350px]">
				Llevá lo que necesitás en cómodas cuotas
			</p>
		</div>

		{/* Beneficio 3: Corazón / Atención */}
		{/* MODIFICADO: justify-end para alinear el contenido a la derecha de su columna */}
		<div class="benefit-item flex flex-col items-center justify-end gap-6 transition-all duration-500" style="transition-delay: 240ms">
			<Image
				src={corazon}
				alt=""
				class="h-[43px] w-auto object-contain transition-transform duration-300 hover:scale-110"
			/>
			<p class="text-white text-[24px] font-bold max-w-[350px]">
				Atención rápida, segura y personalizada
			</p>
		</div>

	</div>
</section>

<script>
	if ('IntersectionObserver' in window) {
		const items = document.querySelectorAll<HTMLElement>('.benefit-item');

		const observer = new IntersectionObserver(
			(entries) => {
				entries.forEach((entry) => {
					if (entry.isIntersecting) {
						entry.target.classList.remove('opacity-0', 'translate-y-6');
						observer.unobserve(entry.target);
					}
				});
			},
			{ threshold: 0.2 },
		);

		items.forEach((item) => {
			item.classList.add('opacity-0', 'translate-y-6');
			observer.observe(item);
		});
	}
</script>
