---
import { Image } from 'astro:assets';
import footerImage from '../assets/footer.png';
import mano_regalo from '../assets/mano_regalo.png';
import moneda from '../assets/moneda.png';
import corazon from '../assets/corazon.png';
---

{/* 100dvh en móvil para que ocupe la pantalla completa; altura fija de 489px y centrado flex para desktop */}
<section class="relative overflow-hidden py-16 h-[100dvh] md:h-[50dvh] flex items-center">
	<Image src={footerImage} alt="" class="absolute inset-0 h-full w-full object-cover" />
	<div class="absolute inset-0 bg-brand-pink/20"></div>

	{/* Ajustamos el ancho completo para que el grid se alinee bien al estar dentro de un flex */}
	<div class="relative z-10 mx-auto grid w-full grid-cols-1 gap-12 px-6 text-center sm:grid-cols-3 max-w-[1600px]">

		{/* Beneficio 1: Regalo / Contado */}
		<div class="benefit-item flex flex-col items-center gap-6 transition-all duration-500">
			<Image
				src={mano_regalo}
				alt=""
				class="h-[66px] w-auto object-contain transition-transform duration-300 hover:scale-110"
			/>
			<p class="text-white text-[24px] font-bold max-w-[350px] mx-auto">
				Comprá al contado con excelentes precios
			</p>
		</div>

		{/* Beneficio 2: Moneda / Cuotas */}
		<div class="benefit-item flex flex-col items-center gap-6 transition-all duration-500" style="transition-delay: 120ms">
			<Image
				src={moneda}
				alt=""
				class="h-[58px] w-auto object-contain transition-transform duration-300 hover:scale-110"
			/>
			<p class="text-white text-[24px] font-bold max-w-[350px] mx-auto">
				Llevá lo que necesitás en cómodas cuotas
			</p>
		</div>

		{/* Beneficio 3: Corazón / Atención */}
		<div class="benefit-item flex flex-col items-center gap-6 transition-all duration-500" style="transition-delay: 240ms">
			<Image
				src={corazon}
				alt=""
				class="h-[43px] w-auto object-contain transition-transform duration-300 hover:scale-110"
			/>
			<p class="text-white text-[24px] font-bold max-w-[350px] mx-auto">
				Atención rápida, segura y personalizada
			</p>
		</div>

	</div>
</section>

<script>
	if ('IntersectionObserver' in window) {
		const items = document.querySelectorAll<HTMLElement>('.benefit-item');

		const observer = new IntersectionObserver(
			(entries) => {
				entries.forEach((entry) => {
					if (entry.isIntersecting) {
						entry.target.classList.remove('opacity-0', 'translate-y-6');
						observer.unobserve(entry.target);
					}
				});
			},
			{ threshold: 0.2 },
		);

		items.forEach((item) => {
			item.classList.add('opacity-0', 'translate-y-6');
			observer.observe(item);
		});
	}
</script>
